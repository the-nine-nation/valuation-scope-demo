{
  "name": "valuation-scope-demo",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "type": "module",
  "scripts": {
    "predev": "npm run db:seed && npm run port:free -- 5566",
    "dev": "npm run dev --prefix apps/web",
    "prebuild": "npm run db:seed",
    "build": "npm run build --prefix apps/web",
    "prestart": "npm run port:free -- 5566",
    "start": "npm run start --prefix apps/web",
    "predeploy": "npm run db:seed",
    "deploy": "npm run deploy --prefix apps/web",
    "admin": "node apps/admin/server.mjs",
    "prices:update": "node tools/scripts/update-prices.mjs",
    "port:free": "node tools/scripts/ensure-port.mjs",
    "db:seed": "node tools/scripts/seed-stock-db.mjs",
    "db:generate": "npm run db:generate --prefix apps/web",
    "lookup": "node tools/scripts/lookup-stock.mjs",
    "analysis:ingest": "node tools/scripts/ingest-analysis.mjs",
    "analysis:push": "node tools/scripts/push-source.mjs",
    "test": "npm run build && node --test tools/tests/rendered-html.test.mjs tools/tests/analysis-pipeline.test.mjs",
    "lint": "npm run lint --prefix apps/web"
  },
  "workspaces": [
    "apps/web",
    "apps/admin"
  ]
}
